\frametitle{Python Code }
\begin{lstlisting}
plt.axvline(x=-0.75, color='red', linestyle='--', label='Asymptote')

plt.xlim(-1, 0)
plt.ylim(-10, 10)

plt.title("Nyquist Plot with Low-Frequency Asymptote")
plt.xlabel("Real Axis")
plt.ylabel("Imaginary Axis")
plt.grid()
plt.legend()
plt.savefig('../figs/plt1.png')
plt.show()
    \end{lstlisting}
